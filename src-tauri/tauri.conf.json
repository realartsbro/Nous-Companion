{
  "$schema": "https://raw.githubusercontent.com/nicehash/tauri-schema/v2/schema.json",
  "productName": "Nous Companion",
  "version": "0.1.0",
  "identifier": "com.nous.companion",
  "build": {
    "frontendDist": "../renderer",
    "beforeDevCommand": "",
    "beforeBuildCommand": ""
  },
  "app": {
    "withGlobalTauri": true,
    "windows": [
      {
        "label": "main",
        "title": "Nous Companion",
        "width": 187,
        "height": 267,
        "resizable": false,
        "maximizable": false,
        "decorations": false,
        "shadow": false,
        "alwaysOnTop": true,
        "transparent": false,
        "skipTaskbar": false
      }
    ],
    "security": {
      "csp": "default-src 'self' asset: tauri: http://tauri.localhost https://tauri.localhost; connect-src 'self' ipc: ws: wss: http: https: http://asset.localhost; img-src 'self' data: asset: http://asset.localhost; media-src 'self' blob: data: file: asset: http://asset.localhost; style-src 'self' 'unsafe-inline'; script-src 'self' 'unsafe-inline'",
      "dangerousDisableAssetCspModification": true
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "resources": {
      "../characters/": "characters/",
      "../requirements.txt": "requirements.txt",
      "../scripts/": "scripts/",
      "../src/": "src/"
    },
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  }
}
